{
  "schema_version": 1,
  "phases": [
    {
      "role": "spec_critic",
      "when": {
        "env": "YUKTICASTLE_SPEC_CRITIC"
      },
      "provider": "openai",
      "model": "gpt-5.5",
      "max_iterations": 1
    },
    {
      "role": "implementer",
      "when": "always",
      "provider": "anthropic",
      "model": "claude-opus-4-6",
      "max_iterations": 5,
      "effort": "high"
    },
    {
      "role": "reviewer",
      "when": "always",
      "provider": "openai",
      "model": "gpt-5.5",
      "max_iterations": 3
    }
  ]
}
