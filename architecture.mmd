    classDef data fill:#dbeafe,stroke:#1e40af;
    classDef guard fill:#dcfce7,stroke:#166534,stroke-width:2px;
    class MCP,SPL accent
    class CAT,HINT,POLICY,RAW,OUT,LOG,MD data
    class SV,REVIEW guard
