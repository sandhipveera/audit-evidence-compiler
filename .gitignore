# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Env / secrets
.env
.env.*
!.env.example

# Outputs (xlsx generated by the agent during demos)
*_report.xlsx
gap_report*.xlsx
out/
.aec_cache/

# Splunk
splunk-data/
splunk-logs/
splunk-app/auditcompiler/bin/lib/

# IDE / OS
.DS_Store
.vscode/
.idea/

# Never commit raw client templates from AccessQuint core-biz
core-biz/
*core-biz*

# Hatch build artifacts
dist/
build/

# YuktiCastle agent orchestration (.yukticastle/.env contains secrets)
.yukticastle/.env
.yukticastle/logs/
.yukticastle/worktrees/
# Run history — gitignore by default; commit if you want an audit trail
.yukticastle/runs.jsonl
# Context pack — auto-generated; regenerate with `npm run agents:context`
.yukticastle/context.md
# Learnings ledger — reviewer fix-ups for self-improving prompts
.yukticastle/learnings.jsonl
# Upstream sandcastle library writes per-agent transcripts here;
# main.mts's clean-host preflight already filters this path out,
# but gitignoring it keeps `git status` quiet between runs.
.sandcastle/

# Playwright E2E
test-results/
playwright-report/
tests/.auth/
.playwright/
node_modules/
scripts/
