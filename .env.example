# --- LLM (three-vendor panel) ---
#
# Default transport is OAuth-via-CLI: zero per-call cost, billed against your
# subscription. API keys are fallback for contributors who don't have all three
# CLIs installed. Per-persona transport chain is declared in personas/*.md.
#
# OAuth CLI setup (do this once — no env vars needed):
#   claude login          # Claude Max
#   codex login           # ChatGPT/Codex
#   gemini login          # Google account
#
# Verify with: aec doctor

# --- API-key fallbacks (only used if the matching CLI isn't on PATH) ---

# Anthropic fallback (Auditor persona)
ANTHROPIC_API_KEY=sk-ant-...
AEC_AUDITOR_MODEL=claude-sonnet-4-6

# OpenAI fallback (Engineer persona)
OPENAI_API_KEY=sk-...
AEC_ENGINEER_MODEL=gpt-5

# Google AI Studio fallback (Adversary persona). Free tier ~60 RPM on Gemini 2.5 Pro.
GOOGLE_API_KEY=...
AEC_ADVERSARY_MODEL=gemini-2.5-pro

# OpenRouter last-resort fallback (any persona that exhausts its own vendor chain)
OPENROUTER_API_KEY=sk-or-...

# --- Pipeline (non-panel) reasoning ---
# Control mapping, SPL generation, formatter narrative — single LLM, uses Claude
# via whichever Anthropic transport is available.
AEC_PIPELINE_MODEL=claude-sonnet-4-6

# --- Degradation switches ---
# If true, panel falls back to single-vendor mode when all multi-vendor options
# fail (Claude playing all 3 roles, prompt-only diversity). Reported in audit trail.
AEC_PANEL_SINGLE_VENDOR_FALLBACK=true

# Force a specific transport mode for the panel (useful for benchmarking).
# Values: auto (default) | cli-only | api-only
AEC_PANEL_TRANSPORT_MODE=auto

# --- Splunk ---
# Local Docker default — change for cloud trial
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme-on-first-run
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=false

# --- Splunk MCP Server ---
# Path to local MCP server or HTTP URL
SPLUNK_MCP_URL=http://localhost:8765
SPLUNK_MCP_TRANSPORT=stdio  # or "http"

# --- Optional ---
# Override the priors catalog (defaults to src/aec/priors/catalog.json)
# AEC_CATALOG_PATH=

# Demo mode: use cached SPL results instead of hitting Splunk (for offline demo)
AEC_DEMO_MODE=false
