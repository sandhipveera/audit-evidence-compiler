FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir splunk-mcp 2>/dev/null || \
    pip install --no-cache-dir git+https://github.com/livehybrid/splunk-mcp.git

EXPOSE 8766
CMD ["python", "-m", "splunk_mcp", "--host", "0.0.0.0", "--port", "8766"]
