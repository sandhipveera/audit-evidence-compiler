FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir splunk-mcp-server 2>/dev/null || \
    pip install --no-cache-dir git+https://github.com/splunk/mcp-server-for-splunk.git

EXPOSE 8765
CMD ["python", "-m", "splunk_mcp_server", "--host", "0.0.0.0", "--port", "8765"]
